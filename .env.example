# Exemplo de variáveis de ambiente para o projeto

# URLs de feeds RSS (separe por vírgula)
RSS_FEEDS=https://rss.tecmundo.com.br/feed,https://canaltech.com.br/rss/

# Palavras-chave para filtrar (separe por vírgula)
RSS_KEYWORDS=microsoft,windows,azure,copilot

# Azure AD App (client credentials) - registre um app e crie um segredo
AZURE_CLIENT_ID=seu-client-id
AZURE_CLIENT_SECRET=seu-client-secret
AZURE_TENANT_ID=seu-tenant-id

# SharePoint site/list IDs (pode obter via Graph ou portal)
SHAREPOINT_SITE_ID=seu-site-id
SHAREPOINT_LIST_ID=sua-list-id

# Porta opcional para a visualização local (padrão: 3000)
PORT=3000
